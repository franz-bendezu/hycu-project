{
  "name": "vision-to-blueprint-dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "runServices": ["dev", "postgres", "redis"],
  "workspaceFolder": "/workspaces/hycu-project",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "forwardPorts": [8000, 5173, 5432, 6379],
  "postCreateCommand": "bash -lc 'cd projects/backend && python -m pip install -r requirements.txt && cd ../frontend && npm install'"
}
